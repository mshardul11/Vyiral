# =============================================================================
# Vyiral — copy to .env.local for development, set in host secrets for production
# Run: npm run validate:env  before deploying
# =============================================================================

# Public (embedded in client bundle — never put secrets here)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Canonical app URL (required in production — used for OAuth redirects & origin checks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only — never expose to the browser
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Use literal \n for newlines when storing in a single line (Vercel/hosting panels)
FIREBASE_ADMIN_PRIVATE_KEY=

# AI & YouTube (optional until those features are enabled)
OPENAI_API_KEY=
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/youtube/channel-connect/callback

# Node
NODE_ENV=development
